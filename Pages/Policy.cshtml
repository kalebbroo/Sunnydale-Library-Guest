@page
@model PolicyModel
@{
    ViewData["Title"] = "Library Policy";
}

<section class="card policy">
    <h1>Library Policy</h1>

    @* TODO(content): rewrite in proper librarian voice once we land on the final tone. *@
    <p>By signing in to the Sunnydale Library guest network you agree:</p>
    <ul>
        <li>Not to start any apocalypses on the premises.</li>
        <li>To return all borrowed knowledge before sundown.</li>
        <li>To respect the silence (and the librarian).</li>
        <li>That access is provided as-is, may be revoked, and is logged for security purposes.</li>
    </ul>

    <p><a href="/">&larr; Back to sign-in</a></p>
</section>
