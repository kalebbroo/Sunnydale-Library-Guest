@{
    string title = ViewData["Title"] as string ?? "Sunnydale High School Library";
}<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#3a2418" />
    <meta name="referrer" content="no-referrer" />
    <title>@title</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" href="~/favicon.ico" />
</head>
<body>
    <main class="library">
        @RenderBody()
    </main>
    @* For the curious who view-source the register — a little something from the stacks. *@
    <!--
       SUNNYDALE HIGH SCHOOL LIBRARY  ·  property of the Watchers Council

                |
               /|\     "In every generation there is a Chosen One.
              / | \      She alone will stand against the vampires,
                |        the demons, and the forces of darkness.
                V        She is the Slayer."

       You found the Restricted Section. Pick a Reason that's... slaying-related,
       and tap the stake. It's called Mr. Pointy.            - R.G.
    -->
</body>
</html>
