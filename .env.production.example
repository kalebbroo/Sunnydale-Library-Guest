# Copy to .env.production on the deploy host and fill in real values.
# Never commit the populated file.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# UniFi controller — local admin account, NOT a UI.com cloud account.
# For UDM family (UDM / UDM-Pro / UDM-SE / UDR) use just https://<lan-ip> (port 443 implicit).
# For a standalone Network controller, use https://<host>:8443. The portal code targets UniFi OS;
# if you point it at a standalone controller you'll need to revisit the API paths in UnifiClient.cs.
UNIFI_CONTROLLER_URL=https://192.168.1.1
UNIFI_USERNAME=sunnydale-portal
UNIFI_PASSWORD=
UNIFI_SITE=default
UNIFI_DEFAULT_MINUTES=480
UNIFI_VERIFY_TLS=false
# Fail fast if the controller is slow/unreachable instead of hanging the guest's sign-in.
UNIFI_TIMEOUT_SECONDS=10

# Leaderboard / Stake Night game.
# Set a fixed run-token signing key so a restart doesn't invalidate in-flight game tokens.
# Generate one with e.g.: openssl rand -base64 32
LEADERBOARD_SIGNING_KEY=
