# Copy to .env.production on the deploy host and fill in real values.
# Never commit the populated file.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
BASE_URL=https://guest.hartsy.ai

# UniFi controller (UDM SE) — local admin account, NOT a UI.com cloud account
UNIFI_CONTROLLER_URL=https://192.168.1.1:8443
UNIFI_USERNAME=sunnydale-portal
UNIFI_PASSWORD=
UNIFI_SITE=default
UNIFI_DEFAULT_MINUTES=480
UNIFI_VERIFY_TLS=false

# Cloudflare tunnel — get the token from the tunnel dashboard
CLOUDFLARE_TUNNEL_TOKEN=
